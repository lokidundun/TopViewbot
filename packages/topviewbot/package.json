{
  "name": "topviewbot",
  "version": "1.0.1",
  "description": "AI coding assistant with web interface and tunnel support",
  "type": "module",
  "bin": {
    "topviewbot": "./bin/topviewbot"
  },
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun run --conditions=browser ./src/index.ts",
    "build": "bun build ./src/index.ts --outdir=./dist --target=bun",
    "start": "bun run ./src/index.ts",
    "typecheck": "tsc --project tsconfig.check.json"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@hono/node-server": "^1.19.9",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@ngrok/ngrok": "^1.4.1",
    "open": "^10.1.0",
    "ws": "^8.19.0",
    "yargs": "^17.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.33",
    "bun-types": "^1.3.11",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "cli",
    "tunnel",
    "ngrok"
  ],
  "author": "",
  "license": "MIT"
}
